# GlobalMarketAnalyzer — variables de entorno
# Copia este archivo como .env y rellena los valores

# Supabase (opcional — solo para persistencia en DB)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# FRED API — datos macroeconómicos (gratis en https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Telegram Bot — reportes automáticos (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM — análisis de señales (al menos uno requerido)
GROQ_API_KEY=
GEMINI_API_KEY=
